[sub_resource type="Resource" id="Resource_pl5cf"]
script = ExtResource("2_mjpo8")
speaker = "Evil Wizard"
text = "Finally, after, so long... I managed to pull this off... to power all my creations and plunge the world in [color=steelblue]chaos[/color] and [color=steelblue]darkness[/color]..."
metadata/_custom_type_script = "uid://xcsbj0dde8d2"

[sub_resource type="Resource" id="Resource_qg7ps"]
script = ExtResource("2_mjpo8")
speaker = "Evil Wizard"
text = "I stole the [color=orange][shake]SUN[/shake][/color]!"
metadata/_custom_type_script = "uid://xcsbj0dde8d2"

[sub_resource type="Resource" id="Resource_pgein"]
script = ExtResource("2_mjpo8")
speaker = "King"
text = "Not so fast! I, the [color=gold]King[/color] of the entire world, will destroy your [color=orange]Sun-Powered beacon[/color] and return the [color=orange]Sun[/color] back to the sky!"
metadata/_custom_type_script = "uid://xcsbj0dde8d2"

[sub_resource type="Resource" id="Resource_mjpo8"]
script = ExtResource("2_mjpo8")
speaker = "Evil Wizard (you)"
text = "Ha ha ha ha... My canon are stronger than entire fleet! Bring it on!"
metadata/_custom_type_script = "uid://xcsbj0dde8d2"

[sub_resource type="Resource" id="Resource_vwyhe"]
script = ExtResource("2_mjpo8")
speaker = "Tutorial"
text = "Use scrollwheel or press 'Q' to select the canon.
Press LMB to place it on the field. Be aware, [wave freq=2][color=orange]canons must be powered by the Sun[/color]."
metadata/_custom_type_script = "uid://xcsbj0dde8d2"

[sub_resource type="Resource" id="Resource_vwykj"]
